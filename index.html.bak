<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Central Architects</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <!-- Фіксована шапка -->
  <header class="header">
    <div class="header-container">
      <a href="#" class="logo">CENTRAL ARCHITECTS</a>
      <nav class="nav-menu">
        <a href="#home" class="nav-link active">ГОЛОВНА</a>
        <a href="#projects" class="nav-link">НАШІ ПРОЄКТИ</a>
        <a href="#contacts" class="nav-link">КОНТАКТИ</a>
      </nav>
    </div>
  </header>

  <!-- Головний екран (Hero Section) -->
  <section id="home" class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1 class="hero-title">CENTRAL ARCHITECTS</h1>
      <p class="hero-subtitle">architectural design studio</p>
    </div>
  </section>

  <!-- Розділ проєктів -->
  <section id="projects" class="projects-section">
    <div class="container">
      <!-- Тут розміщуються ваші картки проєктів -->
    </div>
  </section>

</body>
</html>